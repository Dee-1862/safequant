# Copy to .env in the repo root and edit. Never commit .env.
#
# On Bridges-2, run `accounts` on the login node for SLURM_ACCOUNT and
# OCEAN_ALLOCATION (the folder name under /ocean/projects/).

# --- local workstation (uncomment) ---
# REPO_ROOT=/path/to/safequant
# HF_HOME=/data/huggingface
# QM_ROOT=/data/quantized_models

# --- Bridges-2 (uncomment and replace placeholders) ---
# SLURM_ACCOUNT=YOUR_SLURM_ACCOUNT
# OCEAN_ALLOCATION=YOUR_OCEAN_ALLOCATION
# REPO_ROOT=/jet/home/youruser/projects/safequant
# HF_HOME=/ocean/projects/YOUR_OCEAN_ALLOCATION/youruser/.cache/huggingface
# QM_ROOT=/ocean/projects/YOUR_OCEAN_ALLOCATION/youruser/quantized_models
# CONDA_ENV=/ocean/projects/YOUR_OCEAN_ALLOCATION/youruser/conda_envs/sq_clean
# AGENV=/ocean/projects/YOUR_OCEAN_ALLOCATION/youruser/conda_envs/sq_autogptq
# AQLM_REPO=/jet/home/youruser/projects/AQLM
